DATABASE_URL=file:/home/z/my-project/db/custom.db

# Cloudinary Configuration
# Get your credentials from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Required for next-cloudinary (CldImage, getCldImageUrl in the browser). Usually same as CLOUDINARY_CLOUD_NAME.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=dmpusyiad

# Google AI (Gemini) for admin assistant chat — server-side only, never exposed to the browser
GOOGLE_API_KEY=

# Model për Gemini (default: gemini-2.5-flash; nëse një model dështon me 429/404/503, provohen të tjerët automatikisht)
# GEMINI_MODEL=gemini-1.5-flash
